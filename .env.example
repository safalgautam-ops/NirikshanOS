# Copy this file to .env and adjust values for your local setup.

# App
SECRET_KEY=change-me-to-a-random-value
QUART_DEBUG=true

# MySQL (used by the web/worker containers to connect)
DB_HOST=mysql
DB_PORT=3306
DB_USER=nirikshan
DB_PASSWORD=nirikshan
DB_NAME=nirikshan

# MySQL (used by the mysql container itself on first init)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=nirikshan
MYSQL_USER=nirikshan
MYSQL_PASSWORD=nirikshan

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage) - avatars, org logos, org
# documents, and case evidence all live here (see app/core/object_storage.py).
# MINIO_ENDPOINT is the in-container address used for the app's own S3
# calls; MINIO_PRESIGN_ENDPOINT must be browser-reachable, since a presigned
# URL bakes in whatever host signed it ("minio" doesn't resolve outside the
# compose network); MINIO_PUBLIC_URL is what browsers use to fetch public
# assets, proxied by nginx's /media/ location.
MINIO_ENDPOINT=http://minio:9000
MINIO_PRESIGN_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost/media
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PUBLIC=nirikshan-public
MINIO_BUCKET_PRIVATE=nirikshan-private

# Public base URL (used to build OAuth callback URLs)
APP_URL=http://localhost:8000

# Analysis job workspaces — must be a host path so docker bind mounts work correctly.
# The worker container and the host Docker daemon must both resolve this path identically.
JOBS_DIR=/storage/jobs

# Docker image allowlist for the analysis worker. Only images listed here can be
# scheduled as analysis jobs. Build the base image first:
#   docker compose --profile build-only build analyzer-base
ALLOWED_RUNTIME_IMAGES=nirikshan/base:1.0

# Resend (email) - get a key at resend.com; leave blank to print to stdout in dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=NirikshanOS <noreply@yourdomain.com>

# Google OAuth - create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth - create at github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

