# Copy this file to .env and adjust values for your local setup.

# App
SECRET_KEY=change-me-to-a-random-value
QUART_DEBUG=true

# MySQL (used by the web/worker containers to connect)
DB_HOST=mysql
DB_PORT=3306
DB_USER=nirikshan
DB_PASSWORD=nirikshan
DB_NAME=nirikshan

# MySQL (used by the mysql container itself on first init)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=nirikshan
MYSQL_USER=nirikshan
MYSQL_PASSWORD=nirikshan

# Redis
REDIS_URL=redis://redis:6379/0

# Public base URL (used to build OAuth callback URLs)
APP_URL=http://localhost:8000

# Resend (email) - get a key at resend.com; leave blank to print to stdout in dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=NirikshanOS <noreply@yourdomain.com>

# Google OAuth - create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth - create at github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# WebAuthn / Passkeys - RP = your domain (no port, no https:// prefix)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NirikshanOS
WEBAUTHN_RP_ORIGIN=http://localhost:8000
